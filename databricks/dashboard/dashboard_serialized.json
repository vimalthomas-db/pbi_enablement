{
  "datasets": [
    {
      "name": "ds_sales",
      "displayName": "Sales Metrics",
      "queryLines": [
        "SELECT order_date, order_status, product_name, product_category,\n",
        "  rep_name, territory, customer_name, customer_segment, region,\n",
        "  year, quarter, CONCAT(year, ' Q', quarter) as quarter_label,\n",
        "  MEASURE(`Total Revenue`) as total_revenue,\n",
        "  MEASURE(`Total Profit`) as total_profit,\n",
        "  MEASURE(`Order Count`) as order_count,\n",
        "  MEASURE(`Profit Margin`) as profit_margin,\n",
        "  MEASURE(`Avg Order Value`) as avg_order_value,\n",
        "  MEASURE(`Revenue Completed`) as revenue_completed,\n",
        "  MEASURE(`Total Quantity`) as total_quantity\n",
        "FROM vjoseph_pbi_demo.pbi_retail_demo.sales_metrics_full\n",
        "GROUP BY order_date, order_status, product_name, product_category,\n",
        "  rep_name, territory, customer_name, customer_segment, region, year, quarter"
      ]
    },
    {
      "name": "ds_support",
      "displayName": "Support Metrics",
      "queryLines": [
        "SELECT created_at, priority, status,\n",
        "  MEASURE(`Ticket Count`) as ticket_count,\n",
        "  MEASURE(`Avg Resolution Hours`) as avg_resolution_hours,\n",
        "  MEASURE(`Avg CSAT`) as avg_csat,\n",
        "  MEASURE(`Open Tickets`) as open_tickets\n",
        "FROM vjoseph_pbi_demo.pbi_retail_demo.support_metrics\n",
        "GROUP BY created_at, priority, status"
      ]
    },
    {
      "name": "ds_support_detail",
      "displayName": "Support Ticket Details",
      "queryLines": [
        "SELECT ticket_id, customer_name, priority, status,\n",
        "  issue_description, resolution_hours, csat_score, created_at\n",
        "FROM vjoseph_pbi_demo.pbi_retail_demo.vw_support_detail\n",
        "ORDER BY created_at DESC"
      ]
    }
  ],
